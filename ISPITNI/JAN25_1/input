package ISPITNI.JAN25_1;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.Stack;

public class Main{
    public static void main(String[] args) throws IOException {

        BufferedReader br= new BufferedReader(new InputStreamReader(System.in));
        int n= Integer.parseInt(br.readLine());
        Stack <String> stack= new Stack<>();
        boolean isValid= true;

        for (int i=0; i<n; i++){
            String line= br.readLine().trim();

            if (line.startsWith("#")){
                if (line.equals("#Body")){
                    stack.push(line);
                } else if (line.matches("#Heading[1-6]")) {
                    int current= Integer.parseInt(line.substring(8));

                    if (stack.contains("#Body")){
                        isValid=false;
                        break;
                    }
                    if (!stack.isEmpty() && stack.peek().matches("#Heading[1-6]")){
                        int previous= Integer.parseInt(stack.peek().substring(8));
                        if (previous>current){
                            isValid=false;
                            break;
                        }
                    }
                    stack.push(line);
                }

            } else if (line.endsWith("#")) {
                if (line.equals("Body#")){
                    if (stack.isEmpty() || !stack.peek().equals("#Body")){
                        isValid=false;
                        break;
                    }
                    stack.pop();
                }
                if (line.matches("Heading[1-6]#")){
                    if (!stack.isEmpty() || stack.peek().matches("Heading[1-6]#")){
                        int number= Integer.parseInt(line.substring(7,8));
                        String expected= "#Heading"+number;
                        if (stack.isEmpty() || !stack.peek().matches(expected)){
                            isValid=false;
                            break;
                        }
                        stack.pop();
                    }
                }
            }

        }
        if (!stack.isEmpty()){
            isValid=false;
        }
        System.out.println(isValid ? "True" : "False");
    }
}





